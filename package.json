{
  "name": "arcane-cli",
  "version": "0.13.0",
  "description": "Arcane framework CLI — scaffold and manage governance files in consuming repositories",
  "keywords": [
    "arcane",
    "cli",
    "sdlc",
    "methodology",
    "governance",
    "ai-agents",
    "agent",
    "spell",
    "scaffolding",
    "templates"
  ],
  "homepage": "https://github.com/codemagicianhq/arcane#readme",
  "bugs": "https://github.com/codemagicianhq/arcane/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codemagicianhq/arcane.git"
  },
  "license": "MIT",
  "author": "Code Magician LLC",
  "type": "module",
  "bin": {
    "spell": "dist/index.js",
    "arcane": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup && tsx scripts/copy-assets.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit",
    "check:version-bump": "tsx scripts/check-version-bump.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@inquirer/prompts": "^6.0.0",
    "chalk": "^5.6.2",
    "commander": "^12.0.0",
    "gradient-string": "^3.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}
